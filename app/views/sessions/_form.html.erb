<%= polaris_page do %>
    <%= polaris_vertical_stack(inline_align: :center, gap: '5') do %>
      <%= form_with(url: sign_in_path, method: :post, local: false) do |form| %>
        <%= polaris_vertical_stack(gap: "3") do %>
          <%= polaris_text_field(
                name: :email,
                label: "Email",
                value: params[:email_hint],
                required: true,
                autofocus: true,
                autocomplete: "email"
              ) %>

          <%= polaris_text_field(
                name: :password,
                label: "Password",
                type: :password,
                required: true,
                autocomplete: "current-password"
              ) %>

          <%= polaris_button(submit: true, primary: true) { "Sign in" } %>
        <% end %>
      <% end %>

      <%= polaris_text(label: "") do %>
        <%= link_to "Sign up", sign_up_path, data: { turbo_frame: "_top" } %> |
        <%= link_to "Forgot your password?", new_identity_password_reset_path, data: { turbo_frame: "_top" } %>
      <% end %>
    <% end %>
<% end %>
